{
  "name": "sigil",
  "version": "0.1.0",
  "description": "Capability registry for Uncaged — LRU-managed Cloudflare Workers",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240405.0",
    "pnpm": "^10.33.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0",
    "wrangler": "^3.50.0"
  }
}
